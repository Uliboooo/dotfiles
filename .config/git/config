[init]
	defaultBranch = main
[user]
	name = seli
	email = l1lan@proton.me
[includeIf "gitdir:/Users/"]
  path = ~/.config/git/config_mac
[core]
	excludesfile = ~/.gitignore_global
	pager = less

[diff]
	tool = difftastic
	external = difft

[difftool]
	prompt = false

[difftool "difftastic"]
	cmd = difft --display inline "$LOCAL" "$REMOTE"

[pager]
	difftool = true

[credential "https://github.com"]
	helper =
	helper = !gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !gh auth git-credential

[color]
  ui = auto
[color "status"]
  modified = yellow
  deleted = red
[pull]
	rebase = false
