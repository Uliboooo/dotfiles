" Terminal toggle state
let g:term_buf = 0
let g:term_win = 0
let g:term_small = 1

function! TermToggle(height)
    if win_gotoid(g:term_win)
        hide
    else
        " Check if terminal buffer exists and is valid
        if g:term_buf != 0 && bufexists(g:term_buf) && getbufvar(g:term_buf, '&buftype') ==# 'terminal'
            botright split
            exec "resize " . a:height
            exec "buffer " . g:term_buf
        else
            " Create new terminal
            botright new
            exec "resize " . a:height
            terminal ++curwin
            let g:term_buf = bufnr("")
            " Configure terminal buffer
            setlocal nonumber
            setlocal norelativenumber
            setlocal signcolumn=no
            setlocal nospell
            setlocal winfixheight
            setlocal nobuflisted
        endif
        startinsert!
        let g:term_win = win_getid()
    endif
endfunction

" Toggle terminal with Ctrl+\
nnoremap <silent> <C-\> :call TermToggle(20)<CR>
tnoremap <silent> <C-\> <C-\><C-n>:call TermToggle(20)<CR>

" Resize terminal with Ctrl+_
nnoremap <silent> <C-_> :call TermResize()<CR>
tnoremap <silent> <C-_> <C-\><C-n>:call TermResize()<CR>i

function! TermResize()
    if g:term_small
        exec "resize " . (&lines - 5)
        let g:term_small = 0
    else
        exec "resize 20"
        let g:term_small = 1
    endif
endfunction

