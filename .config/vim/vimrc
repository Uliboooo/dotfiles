" Function to set colorscheme based on background
function! SetColorscheme()
  try
    if &background == 'light'
      " Use light variant if available, otherwise standard
      colorscheme rosepine
      " Rose-pine will auto-adjust to light background
    else
      colorscheme rosepine
      " Rose-pine will auto-adjust to dark background
    endif
  catch
    colorscheme default
  endtry
  " Re-apply transparent background
  hi Normal guibg=NONE ctermbg=NONE
  hi NonText guibg=NONE ctermbg=NONE
  hi LineNr guibg=NONE ctermbg=NONE
  hi SignColumn guibg=NONE ctermbg=NONE
  hi EndOfBuffer guibg=NONE ctermbg=NONE
endfunction

" Function to toggle between dark and light modes
function! ToggleBackground()
  if &background == 'dark'
    set background=light
  else
    set background=dark
  endif
  call SetColorscheme()
  " Update lightline colorscheme
  call lightline#colorscheme()
  call lightline#update()
endfunction

" Create user command for toggling
command! ToggleBackground call ToggleBackground()

