" Keep fzf preview (bat) in sync with current light/dark theme.
function! s:BatThemeList() abort
  if !exists('s:bat_theme_list')
    if executable('bat')
      let s:bat_theme_list = systemlist('bat --list-themes')
    elseif executable('batcat')
      let s:bat_theme_list = systemlist('batcat --list-themes')
    else
      let s:bat_theme_list = []
    endif
  endif
  return s:bat_theme_list
endfunction

function! s:HasTheme(themes, name) abort
  if type(a:themes) != type([])
    return 0
  endif

  for l:theme_name in a:themes
    if l:theme_name ==# a:name
      return 1
    endif
  endfor

  return 0
endfunction

function! s:ApplyFzfPreviewTheme() abort
  if &background ==# 'light'
    let l:candidates = ['rose-pine-dawn', 'Catppuccin Latte', 'GitHub']
  else
    let l:candidates = ['rose-pine-moon', 'Catppuccin Mocha', 'TwoDark']
  endif

  let l:themes = s:BatThemeList()

  for l:theme in l:candidates
    if s:HasTheme(l:themes, l:theme)
      let $BAT_THEME = l:theme
      return
    endif
  endfor

  unlet! $BAT_THEME
endfunction

