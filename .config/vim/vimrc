" Apply colorscheme based on &background
function! SetColorscheme() abort
  try
    if &background ==# 'light'
      colorscheme rosepine_dawn
    else
      colorscheme rosepine_moon
    endif
  catch
    colorscheme default
  endtry

  call s:ApplyTerminalPalette()
  call s:ApplyFzfPreviewTheme()

  " Re-apply transparent background
  hi Normal guibg=NONE ctermbg=NONE
  hi NonText guibg=NONE ctermbg=NONE
  hi LineNr guibg=NONE ctermbg=NONE
  hi SignColumn guibg=NONE ctermbg=NONE
  hi EndOfBuffer guibg=NONE ctermbg=NONE
endfunction

" Toggle between dark/light and refresh lightline
function! ToggleBackground() abort
  if &background ==# 'dark'
    set background=light
  else
    set background=dark
  endif

  let g:lightline.colorscheme = (&background ==# 'light') ? 'rosepine_dawn' : 'rosepine_moon'
  call SetColorscheme()
  call lightline#colorscheme()
  call lightline#update()
endfunction

command! ToggleBackground call ToggleBackground()

