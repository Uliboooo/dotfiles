# ---------------------------------------------------------------------
# change dir
# ---------------------------------------------------------------------
abbr cdd="cd \$HOME/Develop"
abbr cdn="cd \$HOME/Documents/notes/"
abbr cdr="cd \$HOME/Recent/"
abbr g='cd "$(ghq list | fzf --preview 'ls $(ghq root)/{}')"'

# ---------------------------------------------------------------------
# git
# ---------------------------------------------------------------------
abbr gst="git status"
abbr gda="git --no-pager diff"
abbr gln="git log --all --date-order --date=format:'%y-%m-%d %H:%M' --graph --format=' <%h> %ad [%an] %C(green)%d%Creset %s'"
abbr gla="git --no-pager log --all --date-order --date=format:'%y-%m-%d %H:%M' --graph --format=' <%h> %ad [%an] %C(green)%d%Creset %s'"
# abbr gls="git --no-pager log --all --date-order --date=format:'%Y-%m-%d' --graph --format=' <%h> %ad [%an] %C(green)%d%Creset %s' -n 15"
abbr gls="git --no-pager log --all --date-order --date=format:'%y-%m-%d %H:%M' --graph --format=' <%h> %ad [%an] %C(green)%d%Creset %s' -n 15"
abbr gf="git fetch"
abbr ghp="echo 'restora only a portion of the data.'"
abbr gbs="git switch"
abbr gbc="git switch -c"
abbr gb="git branch"

# ---------------------------------------------------------------------
# utility / vim / tmux
# ---------------------------------------------------------------------
abbr lss="ls -l"
# abbr ff="fastfetch"
abbr ls="eza -l --icons=always"
abbr glist="/bin/ls"
abbr printimg="chafa -f kitty"
abbr cow="cowsay"
abbr mi="mediainfo"
abbr nv="nvim"
abbr nvd="nvim ."
abbr nnv="nightly_nvim"
abbr nnvd="nightly_nvim ."
abbr tl="tmux ls"
abbr tmr="tmux kill-session -t"
abbr rtss="rts -cli | jq -r '.list[] | \"title: \(.title)\nlink: \(.link)\"'"
abbr rg="rg --hidden"
abbr fd="fd"

abbr y="yazi"
abbr l="lazygit"

# ---------------------------------------------------------------------
# cargo / rust
# ---------------------------------------------------------------------
abbr cb="cargo build"
abbr cr="cargo run"
abbr cf="cargo fmt"
abbr ch="cargo check"
abbr cn="cp ~/dotfiles/rust_dev_temp/flake.nix ./flake.nix && ls ./flake.nix"

abbr nd='nix develop -c $SHELL'

# ---------------------------------------------------------------------
# C / C++
# ---------------------------------------------------------------------
abbr cpr="clang++ main.cpp -o out && ./out"

# ---------------------------------------------------------------------
# MoonBit
# ---------------------------------------------------------------------
abbr mb="moon build"
abbr mr="moon run"
abbr mf="moon fmt"
abbr mh="moon check"

# ---------------------------------------------------------------------
# OS依存 (macOS / Linux)
# ---------------------------------------------------------------------
abbr copy="wl-copy"
abbr cc="clang"
abbr ccc="clang++"
abbr hxd="hx ."

abbr update="yay -Syu --noconfirm"

abbr :q="exit"
abbr :Q="exit"
abbr :wq="exit"
abbr :Wq="exit"

abbr reboot="systemctl reboot"

# ---------------------------------------------------------------------
# NixOS
# ---------------------------------------------------------------------
abbr nbuild="sudo nixos-rebuild switch --flake .#desktop"
abbr nupdate="nix flake update nixpkgs"
