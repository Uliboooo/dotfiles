:: resize @

alt - q : yabai -m window --close
alt - t : open -na "kitty"
alt - e : open -a Finder ~
alt - d : open -a Raycast
alt - v : yabai -m window --toggle float
alt - f : yabai -m window --toggle zoom-fullscreen
alt - j : yabai -m window --toggle split
alt + shift - v : open "raycast://extensions/raycast/raycast/clipboard-history"
alt + shift - e : /System/Library/CoreServices/Menu\ Extras/User.menu/Contents/Resources/CGSession -suspend
alt - m : yabai --stop-service
alt - c : open "x-apple.systempreferences:com.apple.Notifications-Settings.extension"

alt - left : yabai -m window --focus west
alt - right : yabai -m window --focus east
alt - up : yabai -m window --focus north
alt - down : yabai -m window --focus south
alt - h : yabai -m window --focus west
alt - l : yabai -m window --focus east

alt - 1 : yabai -m space --focus 1
alt - 2 : yabai -m space --focus 2
alt - 3 : yabai -m space --focus 3
alt - 4 : yabai -m space --focus 4
alt - 5 : yabai -m space --focus 5
alt - 6 : yabai -m space --focus 6
alt - 7 : yabai -m space --focus 7
alt - 8 : yabai -m space --focus 8
alt - 9 : yabai -m space --focus 9
alt - 0 : yabai -m space --focus 10

alt + shift - 1 : yabai -m window --space 1; yabai -m space --focus 1
alt + shift - 2 : yabai -m window --space 2; yabai -m space --focus 2
alt + shift - 3 : yabai -m window --space 3; yabai -m space --focus 3
alt + shift - 4 : yabai -m window --space 4; yabai -m space --focus 4
alt + shift - 5 : yabai -m window --space 5; yabai -m space --focus 5
alt + shift - 6 : yabai -m window --space 6; yabai -m space --focus 6
alt + shift - 7 : yabai -m window --space 7; yabai -m space --focus 7
alt + shift - 8 : yabai -m window --space 8; yabai -m space --focus 8
alt + shift - 9 : yabai -m window --space 9; yabai -m space --focus 9
alt + shift - 0 : yabai -m window --space 10; yabai -m space --focus 10

alt + shift - h : yabai -m window --swap west
alt + shift - l : yabai -m window --swap east

f13 : screencapture -w ~/Pictures/Screenshots/$(date +%Y-%m-%d-%H%M%S).png
alt - p : screencapture -w ~/Pictures/Screenshots/$(date +%Y-%m-%d-%H%M%S).png
ctrl + shift - s : screencapture -i ~/Pictures/Screenshots/$(date +%Y-%m-%d-%H%M%S).png
alt - f13 : screencapture ~/Pictures/Screenshots/$(date +%Y-%m-%d-%H%M%S).png

alt - k : osascript -e 'tell application "Music" to playpause'

alt - s : yabai -m space --focus 9
alt + shift - s : yabai -m window --space 9; yabai -m space --focus 9
alt - grave : yabai -m space --focus 10
alt + shift - grave : yabai -m window --space 10; yabai -m space --focus 10
alt - backslash : yabai -m space --focus 10
alt + shift - backslash : yabai -m window --space 10; yabai -m space --focus 10

alt - r ; resize
resize < h : yabai -m window --resize left:-20:0
resize < l : yabai -m window --resize right:20:0
resize < k : yabai -m window --resize top:0:-20
resize < j : yabai -m window --resize bottom:0:20
resize < escape ; default
