# Empty values reset the configuration to the default value
font-family = "0xProto Nerd Font"
# font-family = "ComicShannsMono Nerd Font"
# font-family = "Victor Mono"
font-family = "Cica"
font-size = 11.5

# font-feature = "-calt,-liga,-dlig"
cursor-opacity = 0.2
cursor-style = bar

window-height = 100
window-width = 200

# background-image-opacity = 1.5
background-image-fit = cover

background-opacity = 0.96
background-blur-radius = 20

#  ╔╦╗ ╦ ╦ ╔═╗ ╔╦╗ ╔═╗
#   ║  ╠═╣ ║╣  ║║║ ║╣
#   ╩  ╩ ╩ ╚═╝ ╩ ╩ ╚═╝
# theme = catppuccin-frappe
# theme = catppuccin-macchiato
# theme = catppuccin-mocha
theme = rose-pine-moon

window-theme = dark

cursor-style-blink = true

# conf of quickterm
quick-terminal-position = "top"
quick-terminal-screen = "main"
quick-terminal-animation-duration = 0.3
keybind = "global:option+shift+t=toggle_quick_terminal"

# split term
keybind = ctrl+shift+down=new_split:down
keybind = ctrl+shift+right=new_split:right
keybind = ctrl+shift+up=new_split:up
keybind = ctrl+shift+left=new_split:left

# move splited term
keybind = ctrl+h=goto_split:left
keybind = ctrl+l=goto_split:right
keybind = ctrl+j=goto_split:bottom
keybind = ctrl+k=goto_split:top

# disable toggle fullscreen
keybind = super+enter=unbind
keybind = ctrl+enter=unbind

window-inherit-working-directory = true
term=xterm-256color

notify-on-command-finish = unfocused
notify-on-command-finish-action = bell,notify
notify-on-command-finish-after = 5s

