// -*- mode: jsonc -*-
{
  "layer": "top",
  "position": "top",
  "height": 30,
  "spacing": 0,
  "modules-left": ["hyprland/workspaces", "custom/hypr-windows"],
  "modules-center": ["hyprland/submap", "mpris", "clock"],
  "modules-right": [
    "temperature",
    "pulseaudio",
    "bluetooth",
    "network",
    "battery",
    "custom/tlp",
    "tray",
    "custom/notification"
  ],
  "hyprland/workspaces": {
    "format": "{name}",
    "show-special": true,
    "on-click": "activate",
    "all-outputs": false,
    "format-icons": {
      "active": "οÜ£",
      "default": "ο³¨",
      "urgent": "ο¹Σ"
    }
  },
  "custom/hypr-windows": {
    "exec": "~/dotfiles/.config/waybar/scripts/hypr-ws-windows.sh",
    "return-type": "json",
    "escape": false,
    "tooltip": true
  },
  "hyprland/submap": {
    "format": "{}",
    "max-length": 25,
    "tooltip": false,
    "show-empty": false
  },

  "mpris": {
    "format": "σΑéÜ {artist} - {title}",
    "format-paused": "σΑèΛ <i>{artist} / {title}</i>",
    "max-length": 35,
    "player-icons": {
      "default": "σΑéÜ"
    }
  },
  "clock": {
    "format": "{:%b %d %a %H:%M}",
    "tooltip-format": "<tt>{calendar}</tt>",
    "calendar": {
      "mode": "month",
      "on-scroll": 1,
      "format": {
        "months": "<span color='#d38ca0'><b>{}</b></span>",
        "days": "<span color='#2d302b'>{}</span>",
        "today": "<span color='#fbf9f2' background='#d38ca0'><b>{}</b></span>"
      }
    }
  },

  "temperature": {
    "critical-threshold": 80,
    "format-critical": "{icon} {temperatureC}¬ΑC",
    "format": "{icon} {temperatureC}¬ΑC",
    "format-icons": ["ο΄â"],
    "interval": 10,
    "on-click": "kitty --title='dev-float' -e btop"
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "σΑùü MUTED",
    "reverse-mouse-scrolling": true,
    "reverse-scrolling": true,
    "format-icons": {
      "default": ["σΑïΩ", "σΑ•Ä", "σΑïΨ"]
    },
    "on-click": "kitty --class='dev-float' -e wiremix"
  },
  "bluetooth": {
    "format": "οäî{status}",
    "format-connected": "οäî {num_connections}",
    "format-connected-battery": "οäî {device_alias}",
    "on-click": "kitty --class='dev-float' -e bluetui",
    "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%"
  },
  "network": {
    "format-wifi": "ο΅Ϊ {essid}",
    "format-ethernet": "σΑàÄ ETH",
    "format-disconnected": "σΑ•Σ OFFLINE",
    "max-length": 11,
    "on-click": "kitty --class='dev-float' -e ~/dotfiles/script/wifi.bash"
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}{capacity}%",
    "format-charging": "σΑ²³ {capacity}%",
    "format-plugged": "ο΅Π {capacity}%",
    "format-icons": ["σΑ¹Κ", "σΑ¹Μ", "σΑ¹Φ", "σΑ¹Ϋ", "σΑ¹Ψ", "σΑ¹Ω", "σΑ²Ä", "σΑ²¹", "σΑ²²", "σΑ¹Ι"]
  },
  "custom/tlp": {
    "exec": "~/dotfiles/script/tlp-waybar-status.ysh",
    "interval": 10,
    "format": "σΑ¨Σ {}"
  },
  "custom/notification": {
    "tooltip": true,
    "format": "<span size='13pt'>{icon}</span>",
    "format-icons": {
      "notification": "σ±ÖΪ",
      "none": "σΑ²€",
      "dnd-notification": "σΑ²†",
      "dnd-none": "σΑΣ™",
      "inhibited-notification": "σΑ²¦",
      "inhibited-none": "σΑΣë",
      "dnd-inhibited-notification": "σΑ²¦",
      "dnd-inhibited-none": "σΑΣë"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  }
}
