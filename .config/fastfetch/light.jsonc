// this theme changed by uliboooo

{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",

  "logo": {
    "source": "$HOME/.config/fastfetch/ascii.txt",
    "padding": {
      "top": 1,
      "right": 2
    },
    "color": {
      "1": "#E75480"
    }
  },

  "display": {
    "separator": "  ",
    "color": {
      "keys": "#C2185B",
      "title": "#AD1457",
      "separator": "#F48FB1",
      "1": "#C2185B"
    }
  },

  "modules": [
    {
      "type": "title",
      "format": "{#separator}╭────── User : {#separator}{user-name-colored}@{host-name-colored}"
    },

    {
      "type": "custom",
      "format": "{#separator}│ {#separator}System Information"
    },

    {
      "type": "os",
      "key": "{#separator}│  {#separator}󰍹 OS"
    },
    {
      "type": "kernel",
      "key": "{#separator}│  {#separator}󰒋 Kernel"
    },
    {
      "type": "uptime",
      "key": "{#separator}│  {#separator}󰅐 Uptime"
    },
    {
      "type": "packages",
      "key": "{#separator}│  {#separator}󰏓 Packages"
    },
    {
      "type": "users",
      "key": "{#separator}│  {#separator} Users"
    },

    {
      "type": "custom",
      "format": "{#separator}│"
    },

    {
      "type": "custom",
      "format": "{#separator}│ {#separator}Desktop Environment"
    },

    {
      "type": "de",
      "key": "{#separator}│  {#separator}󰧨 DE"
    },
    {
      "type": "wm",
      "key": "{#separator}│  {#separator}󱂬 WM"
    },
    {
      "type": "wmtheme",
      "key": "{#separator}│  {#separator}󰉼 Theme"
    },
    {
      "type": "shell",
      "key": "{#separator}│  {#separator}󰞷 Shell"
    },
    {
      "type": "terminal",
      "key": "{#separator}│  {#separator} Terminal"
    },

    {
      "type": "custom",
      "format": "{#separator}│"
    },

    {
      "type": "custom",
      "format": "{#separator}│ {#separator}Hardware Information"
    },

    {
      "type": "cpu",
      "key": "{#separator}│  {#separator}󰻠 CPU"
    },
    {
      "type": "gpu",
      "key": "{#separator}│  {#separator}󰢮 GPU"
    },
    {
      "type": "memory",
      "key": "{#separator}│  {#separator}󰍛 Memory"
    },
    {
      "type": "disk",
      "key": "{#separator}│  {#separator}󰋊 Disk (/)",
      "folders": "/"
    },

    {
      "type": "custom",
      "format": "{#separator}│"
    },

    {
      "type": "colors",
      "key": "{#separator}│",
      "symbol": "circle"
    },

    {
      "type": "custom",
      "format": "{#separator}╰───────────────────────────────╯"
    }
  ]
}
