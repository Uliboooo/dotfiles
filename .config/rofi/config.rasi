// Rofi Configuration
// Styled to match Waybar design - Catppuccin Mocha

configuration {
    // General settings
    modi: "drun,run,window";
    font: "0xProto Nerd Font 13";
    show-icons: true;
    icon-theme: "Adwaita";
    display-drun: "󰍉";
    display-run: "";
    display-window: "";
    drun-display-format: "{name}";
    
    // Window settings
    width: 50;
    lines: 12;
    columns: 1;
    
    // Behavior
    sort: true;
    sorting-method: "fzf";
    matching: "fuzzy";
    scroll-method: 0;
    disable-history: false;
    
    // Performance
    lazy-filter-limit: 15000;
    
    // Keybindings
    kb-row-up: "Up,Control+k,Control+p";
    kb-row-down: "Down,Control+j,Control+n";
    kb-accept-entry: "Return,KP_Enter";
    kb-remove-to-eol: "";
    kb-mode-next: "Shift+Right,Control+Tab";
    kb-mode-previous: "Shift+Left,Control+ISO_Left_Tab";
    kb-row-left: "Control+Page_Up";
    kb-row-right: "Control+Page_Down";
}

@theme "catppuccin-mocha-waybar"
